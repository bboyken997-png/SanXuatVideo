# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# LLM provider for the ~40% rewrite step: "openai", "anthropic", or "none"
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Models
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Whisper model size: tiny, base, small, medium, large-v3
WHISPER_MODEL=base

# TTS voice (edge-tts). Vietnamese: vi-VN-HoaiMyNeural (female), vi-VN-NamMinhNeural (male)
TTS_VOICE=vi-VN-HoaiMyNeural

# Burned-in subtitle font size (libass 384x288 script space; ~size/288 of height).
# Lower = smaller text. 12-16 is a good range.
SUBTITLE_FONT_SIZE=14

# Target difference ratio for the rewrite (0.0 - 1.0)
TARGET_DIFF_RATIO=0.40

# Max video duration (seconds) the bot will accept
MAX_DURATION_SECONDS=900

# YouTube cookies (needed to bypass "Sign in to confirm you're not a bot").
# Option A: path to a Netscape-format cookies.txt exported from your browser.
YT_COOKIES_FILE=
# Option B: read cookies directly from an installed browser, e.g. "chrome",
# "firefox", or "chrome:/path/to/profile". Used only if YT_COOKIES_FILE is empty.
YT_COOKIES_FROM_BROWSER=

# Restrict bot to these Telegram user IDs (comma-separated). Empty = allow all.
ALLOWED_USER_IDS=
